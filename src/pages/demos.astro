---
import BaseLayout from "../layouts/BaseLayout.astro";

const demos = [
  {
    title: "Interactive demo placeholder",
    desc: "Describe what this demo shows — an algorithm, a dataset, a model behaviour, a visualisation. Make it enticing.",
    tags: ["D3.js", "PyTorch", "WebAssembly"],
    href: "#",
    status: "Live",
  },
  {
    title: "Another visualisation",
    desc: "Another interactive thing. Could be a toy model explorer, an attention map viewer, a loss landscape — whatever you've built.",
    tags: ["Observable", "JavaScript"],
    href: "#",
    status: "Live",
  },
  {
    title: "Work in progress",
    desc: "Something not quite ready yet but you're working on it.",
    tags: ["React", "WASM"],
    href: "#",
    status: "Coming soon",
  },
];
---

<BaseLayout title="Demos" description="Interactive ML demos and visualisations by Georgia Ray." isDemo={true}>

  <section class="section" style="padding-top: 6rem;">
    <div class="container">
      <div class="row" style="margin-bottom: 3rem;">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Demos</h2>
        </div>
        <div class="col-10 animate">
          <p style="font-family: var(--font-serif); font-style: italic; font-size: 1.1rem; line-height: 1.8; color: var(--muted-foreground);">
            Interactive things — visualisations, toy models, and experiments you can poke at.
          </p>
        </div>
      </div>

      <div class="row">
        <div class="col-2"></div>
        <div class="col-10">
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
            {demos.map((demo) => (
              <article class="animate" style="border-radius: 0.75rem; border: 1px solid var(--border); overflow: hidden; background-color: var(--card);">
                <div style="width: 100%; height: 10rem; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; background-color: var(--muted); color: var(--muted-foreground);">
                  {demo.status === "Coming soon" ? "Coming soon" : "[ Interactive preview ]"}
                </div>
                <div style="padding: 1.25rem;">
                  <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.5rem;">
                    <h3 style="font-style: italic; font-size: 1.1rem; font-weight: 500;">{demo.title}</h3>
                    <span class={`tag ${demo.status !== "Live" ? "tag--muted" : ""}`} style="flex-shrink: 0; font-size: 0.7rem;">
                      {demo.status}
                    </span>
                  </div>
                  <p style="font-size: 0.875rem; line-height: 1.65; color: var(--muted-foreground); margin-bottom: 1rem;">{demo.desc}</p>
                  <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
                      {demo.tags.map(tag => <span class="tag tag--muted" style="font-size: 0.7rem;">{tag}</span>)}
                    </div>
                    {demo.status === "Live" && (
                      <a href={demo.href} style="font-size: 0.85rem; color: var(--primary); text-decoration: underline; text-underline-offset: 3px;">Open →</a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
