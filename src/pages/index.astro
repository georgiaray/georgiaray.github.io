---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

  <!-- ═══ INTRO ═══════════════════════════════════════ -->
  <section id="intro" class="section section--intro" style="padding-top: 8rem; padding-bottom: 6rem;">
    <div class="container">
      <div class="row">
        <div class="col-2"></div>
        <div class="col-10">
          <div class="animate hero-intro">
            <div class="hero-intro__row">
              <h1 class="hero-intro__text" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 400; margin: 0;">
                Georgia<br />Ray
              </h1>
              <div class="hero-intro__aside">
                <figure class="hero-intro__photo" style="margin: 0;">
                  <img
                    src="/photos/prof-pic-recolored.jpeg"
                    alt="Portrait of Georgia Ray"
                    loading="eager"
                    decoding="async"
                  />
                </figure>
              </div>
            </div>
            <ul class="hero-intro__meta" style="font-family: var(--font-serif); font-style: italic; font-size: 1.05rem; list-style: none; padding: 0; color: var(--muted-foreground);">
              <li>Machine learning engineer</li>
              <li>Climate researcher</li>
              <li>PhD student</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT ════════════════════════════════════════ -->
  <section id="about" class="section">
    <div class="container">
      <div class="row">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">About me</h2>
        </div>
        <div class="col-10">
          <div style="columns: 2; gap: 2.5rem;">
            <p class="animate" style="margin-bottom: 1.25rem; font-size: 1rem; line-height: 1.8; color: var(--muted-foreground);">
              I'm a climate researcher and machine learning engineer. Currently, I am completing my PhD at Imperial College London's Centre for Environmental Policy with supervision from Professor Joeri Rogelj, Professor Rosella Arcucci, and Dr. Hamish Beath. My focus is on corporate sustainability and machine learning approaches to integrated assessment models and deep decarbonisation pathways. 
              
              I also work as a Machine Learning Engineer at The Chancery Lane Project where we have an organisational focus on decarbonising supply chains through contracts. Personally, I have spearheaded the initiative and helped secure funding for building an institutional knowledge graph to better leverage institutional knowledge in an age of LLMs. 
            </p>
            <p class="animate" style="font-size: 1rem; line-height: 1.8; color: var(--muted-foreground);">
            Outside of research and work, I play way too much football, watch probably the same amount (NFL and Premiere League), read and write, hike and swim, and visit London's endless art galleries. When I run out (or just get the itch), I travel to see more.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EXPERIENCE ═══════════════════════════════════ -->
  <section id="experience" class="section">
    <div class="container">
      <div class="row">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Experience</h2>
        </div>
        <div class="col-10">
          <ul class="feed">
            {[
              {
                period: "Jan 2025 – Present",
                title: "Machine Learning Engineer",
                org: "The Chancery Lane Project",
                location: "London, UK",
                desc: "Part of the UX/Digital team, integrating ML into legal-climate workflows to help decarbonize supply chains through contracts.",
                bullets: [
                  "Developing and improving models that detect and recommend climate clauses in contracts",
                  "Leading work on climate impacts of AI in delivery and team practice",
                  "Helping shape practical data science and ML strategy across product initiatives",
                ],
                tags: ["NLP", "Contract intelligence", "Python", "Applied ML"],
              },
              {
                period: "Jan 2025 – Present",
                title: "Doctoral Student",
                org: "Imperial College London",
                location: "London, UK",
                desc: "PhD research on climate mitigation applications of machine learning, focused on downscaling climate-economy models to sector- and company-level metrics.",
                bullets: [
                  "Combining ML methods with climate modeling and statistical analysis",
                  "Linking technical model outputs to corporate sustainability use-cases",
                  "Advancing interpretable, decision-relevant approaches for decarbonization pathways",
                ],
                tags: ["Climate ML", "Integrated assessment models", "Research"],
              },
              {
                period: "Oct 2024 – Dec 2024",
                title: "Data Science Fellow",
                org: "Faculty",
                location: "London, UK",
                desc: "Completed a competitive fellowship delivering LLM-based tooling for climate clause generation and recommendation in collaboration with TCLP.",
                bullets: [
                  "Fine-tuned an LLM via API for climate clause generation",
                  "Built two NLP models: clause recommendation and company-language identification",
                  "Shipped a Dockerized frontend + API workflow for practical team usage",
                ],
                tags: ["LLMs", "Fine-tuning", "NLP", "Docker"],
              },
              {
                period: "Sep 2023 – Sep 2024",
                title: "Master's Student",
                org: "Imperial College London",
                location: "London, UK",
                desc: "Completed a master's with a research focus on environmental applications of machine learning and remote sensing.",
                bullets: [
                  "Built a single-encoder, double-decoder model for tree crown delineation and species classification",
                  "Applied aerial imagery workflows to improve carbon-accounting transparency",
                  "Connected technical research outputs to climate and sustainability decision contexts",
                ],
                tags: ["Remote sensing", "Computer vision", "Environmental ML"],
              },
              {
                period: "Aug 2021 – Jul 2023",
                title: "Research Associate",
                org: "Environmental Law Institute",
                location: "Washington, DC, USA",
                desc: "Supported interdisciplinary projects on environmental enforcement, digital economy impacts, and environmental technology.",
                bullets: [
                  "Contributed research spanning environmental crimes and intergovernmental enforcement",
                  "Helped coordinate the Research Coordination Network and Digital Economy and the Environment work",
                  "Supported GreenTech-focused initiatives linking policy and emerging technologies",
                ],
                tags: ["Environmental policy", "Research", "Climate governance"],
              },
            ].map((role) => (
              <li class="feed__item animate">
                <div>
                  <div class="feed__item-date">{role.period}</div>
                  <div class="feed__item-company">{role.org}</div>
                  <div class="feed__item-company">{role.location}</div>
                </div>
                <div>
                  <div class="feed__item-title">{role.title}</div>
                  <div class="feed__item-body">
                    <p>{role.desc}</p>
                    <ul>
                      {role.bullets.map(b => <li>{b}</li>)}
                    </ul>
                  </div>
                  <div style="margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.4rem;">
                    {role.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                </div>
              </li>
            ))}
          </ul>

          <!-- Education -->
          <div style="margin-top: 4rem;">
            <h3 style="font-size: 1rem; font-style: italic; font-weight: 500; color: var(--muted-foreground); margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--font-sans);">Education</h3>
            <ul class="feed">
              {[
                {
                  period: "2025 – 2028 (expected)",
                  title: "PhD, Applied Machine Learning and Climate Policy",
                  org: "Imperial College London",
                  desc: "Researching how ML can downscale climate-economy models for sector and company decision-making.",
                },
                {
                  period: "2023 – 2024",
                  title: "Master's Degree (with distinction)",
                  org: "Imperial College London",
                  desc: "Independent research project applying remote sensing and aerial imagery to carbon-accounting tasks.",
                },
                {
                  period: "2017 – 2021",
                  title: "Bachelor's Degree (summa cum laude)",
                  org: "University of Pennsylvania",
                  desc: "Computational Cognitive Science, Urban Studies, and Philosophy of Science.",
                },
              ].map((ed) => (
                <li class="feed__item animate">
                  <div>
                    <div class="feed__item-date">{ed.period}</div>
                    <div class="feed__item-company">{ed.org}</div>
                  </div>
                  <div>
                    <div class="feed__item-title">{ed.title}</div>
                    <div class="feed__item-body"><p>{ed.desc}</p></div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SKILLS ═══════════════════════════════════════ -->
  <section id="skills" class="section">
    <div class="container">
      <div class="row">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Skills &amp; Tools</h2>
        </div>
        <div class="col-5 animate">
          <p style="color: var(--muted-foreground); margin-bottom: 1.5rem; line-height: 1.8;">
            I'm an ML engineer who likes building things end-to-end — from data pipelines to model training to deployment. I care about reproducibility, readable code, and making research useful in practice.
          </p>
          <ul class="list--basic" style="color: var(--foreground); font-size: 0.95rem;">
            <li>Machine learning & deep learning</li>
            <li>NLP & language models</li>
            <li>Experiment design & evaluation</li>
            <li>ML systems & deployment</li>
            <li>Data visualisation & communication</li>
          </ul>
        </div>
        <div class="col-5 animate">
          <p style="color: var(--muted-foreground); margin-bottom: 1.5rem; line-height: 1.8;">
            I try to keep my tooling pragmatic — use what's best for the job. Currently most of my work lives in Python and PyTorch, with a lot of time in the terminal.
          </p>
          <ul class="list--basic" style="color: var(--foreground); font-size: 0.95rem;">
            <li>Python, PyTorch, JAX</li>
            <li>HuggingFace, Weights & Biases</li>
            <li>Docker, GCP / AWS, SLURM</li>
            <li>D3.js, Observable, React</li>
            <li>Git, LaTeX, Jupyter</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ══════════════════════════════════════ -->
  <section id="projects" class="section">
    <div class="container">
      <div class="row" style="margin-bottom: 1.5rem;">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Projects</h2>
        </div>
        <div class="col-5 animate">
          <p style="color: var(--muted-foreground); line-height: 1.8;">ML work, side projects, and things I've built for fun or research.</p>
        </div>
      </div>
      <div class="row">
        <div class="col-2"></div>
        <div class="col-10">
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
            {[
              {
                title: "Project Alpha",
                desc: "Placeholder: a short, accessible description of what this project does and why it's interesting. Avoid jargon where possible.",
                tags: ["PyTorch", "NLP", "Open source"],
                status: "Active",
                github: "#",
              },
              {
                title: "Project Beta",
                desc: "Placeholder: another project. What problem does it solve? What's interesting or novel about the approach?",
                tags: ["Python", "API", "Data viz"],
                status: "Active",
                github: "#",
                demo: "/demos",
              },
              {
                title: "Side thing",
                desc: "Placeholder: a smaller or older project — could be a tool, a dataset, a script, or a weekend hack.",
                tags: ["TypeScript", "CLI"],
                status: "Archived",
                github: "#",
              },
            ].map((p) => (
              <div class="card animate">
                <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.75rem;">
                  <h3 style="font-style: italic; font-size: 1.2rem; font-weight: 500;">{p.title}</h3>
                  <span class={`tag ${p.status === "Archived" ? "tag--muted" : ""}`} style="flex-shrink: 0; margin-top: 0.25rem; font-size: 0.7rem;">
                    {p.status}
                  </span>
                </div>
                <p style="font-size: 0.875rem; line-height: 1.7; color: var(--muted-foreground); margin-bottom: 1rem;">{p.desc}</p>
                <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1rem;">
                  {p.tags.map(tag => <span class="tag tag--muted" style="font-size: 0.7rem;">{tag}</span>)}
                </div>
                <div style="display: flex; gap: 1rem;">
                  <a href={p.github} style="font-size: 0.85rem; color: var(--primary); text-decoration: underline; text-underline-offset: 3px;">GitHub →</a>
                  {p.demo && <a href={p.demo} style="font-size: 0.85rem; color: var(--primary); text-decoration: underline; text-underline-offset: 3px;">Demo →</a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ACADEMIC WRITING ══════════════════════════════ -->
  <section id="academic-writing" class="section">
    <div class="container">
      <div class="row">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Academic Writing</h2>
        </div>
        <div class="col-10">
          {[
            {
              title: "Paper title goes here: a long subtitle that explains the contribution",
              venue: "NeurIPS 20XX",
              authors: "G. Ray, A. Collaborator, B. Another",
              abstract: "Placeholder abstract. A sentence or two about what the paper does, what the key insight is, and what the results show.",
              type: "Conference",
              links: [{ label: "arXiv", href: "#" }, { label: "PDF", href: "#" }, { label: "Code", href: "#" }],
            },
            {
              title: "Another paper title",
              venue: "ICML 20XX",
              authors: "G. Ray, C. Third",
              abstract: "Placeholder abstract. A sentence or two about what the paper does and why it matters.",
              type: "Conference",
              links: [{ label: "arXiv", href: "#" }, { label: "Poster", href: "#" }],
            },
            {
              title: "A workshop paper or preprint",
              venue: "NeurIPS Workshop on [Topic], 20XX",
              authors: "G. Ray",
              abstract: "Placeholder abstract. Workshop paper, preprint, or extended abstract.",
              type: "Workshop",
              links: [{ label: "PDF", href: "#" }],
            },
          ].map((paper) => (
            <article class="animate" style="padding: 1.75rem 0; border-bottom: 1px solid var(--border);">
              <div style="display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span class={`tag ${paper.type === "Workshop" ? "" : ""}`} style={`flex-shrink: 0; margin-top: 0.2rem; font-size: 0.7rem; background-color: ${paper.type === "Conference" ? "var(--primary)" : "var(--accent)"}; color: ${paper.type === "Conference" ? "var(--primary-foreground)" : "var(--accent-foreground)"};`}>
                  {paper.type}
                </span>
                <h3 style="font-style: italic; font-size: 1.15rem; font-weight: 500; line-height: 1.35;">{paper.title}</h3>
              </div>
              <p style="font-size: 0.85rem; color: var(--primary); margin-bottom: 0.25rem; padding-left: 3.5rem;">{paper.venue}</p>
              <p style="font-size: 0.8rem; color: var(--muted-foreground); margin-bottom: 0.75rem; padding-left: 3.5rem;">{paper.authors}</p>
              <p style="font-size: 0.875rem; line-height: 1.7; color: var(--muted-foreground); margin-bottom: 1rem; padding-left: 3.5rem;">{paper.abstract}</p>
              <div style="display: flex; gap: 1.25rem; padding-left: 3.5rem;">
                {paper.links.map(l => (
                  <a href={l.href} target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem; color: var(--primary); text-decoration: underline; text-underline-offset: 3px;">{l.label}</a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CASUAL WRITING ════════════════════════════════ -->
  <section id="writing" class="section">
    <div class="container">
      <div class="row">
        <div class="col-2">
          <h2 class="section-label animate" style="position: sticky; top: 5rem;">Writing</h2>
        </div>
        <div class="col-10">
          {[
            {
              title: "A thing I've been thinking about",
              date: "March 2026",
              tag: "ML",
              excerpt: "Placeholder: a couple of sentences that give the flavour of the piece. What's the question, the observation, or the tension you're exploring?",
              href: "#",
            },
            {
              title: "Why [thing] is more interesting than it sounds",
              date: "January 2026",
              tag: "Explainer",
              excerpt: "Placeholder: this one is more explainer-y — making something technical feel approachable for a non-specialist.",
              href: "#",
            },
            {
              title: "Notes on [paper / concept / experiment]",
              date: "November 2025",
              tag: "Notes",
              excerpt: "Placeholder: informal notes, half-formed thoughts, something you read or tried that you wanted to write down before you forgot it.",
              href: "#",
            },
            {
              title: "Something non-ML",
              date: "September 2025",
              tag: "Other",
              excerpt: "Placeholder: a post about something else you care about — a book, an idea, an observation about the world.",
              href: "#",
            },
          ].map((post) => (
            <a href={post.href} class="writing-item animate">
              <div class="writing-item__meta">
                <span class="tag" style="font-size: 0.7rem;">{post.tag}</span>
                <span>{post.date}</span>
              </div>
              <div class="writing-item__title">{post.title}</div>
              <div class="writing-item__excerpt">{post.excerpt}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT / FOOTER ══════════════════════════════ -->
  <footer id="contact" style="padding: 6rem 0 5rem; overflow: hidden; position: relative; border-top: 1px solid var(--border);">
    <div class="container">
      <div class="row">
        <div class="col-2"></div>
        <div class="col-5">
          <span class="animate" style="
            position: absolute;
            left: -8rem;
            top: -8rem;
            width: 28rem;
            height: 28rem;
            border-radius: 9999px;
            background-color: var(--accent);
            opacity: 0.35;
            z-index: -1;
            pointer-events: none;
          "></span>
          <h2 class="animate" style="font-size: clamp(3rem, 7vw, 6rem); font-style: normal; font-weight: 400; line-height: 1.1; margin-bottom: 2rem; position: relative; z-index: 1;">
            Let's<br />connect
          </h2>
        </div>
        <div class="col-5">
          <p class="animate" style="font-family: var(--font-serif); font-style: italic; font-size: 1.05rem; line-height: 1.9; color: var(--muted-foreground); margin-bottom: 2rem;">
            I'm always happy to chat about research, ML engineering, or anything I've written about.
            Feel free to email me at <a href="mailto:99gray@gmail.com" style="color: var(--foreground); text-decoration: underline; text-underline-offset: 3px;">99gray@gmail.com</a>,
            find me on <a href="https://github.com/georgiaray" target="_blank" rel="noopener noreferrer" style="color: var(--foreground); text-decoration: underline; text-underline-offset: 3px;">GitHub</a>
            or <a href="https://www.linkedin.com/in/georgia-ray-b447ab142/" target="_blank" rel="noopener noreferrer" style="color: var(--foreground); text-decoration: underline; text-underline-offset: 3px;">LinkedIn</a>,
            and see my <a href="https://profiles.imperial.ac.uk/georgia.ray23" target="_blank" rel="noopener noreferrer" style="color: var(--foreground); text-decoration: underline; text-underline-offset: 3px;">Imperial profile</a>.
          </p>
          <p class="animate" style="font-size: 0.8rem; color: var(--muted-foreground);">
            © {new Date().getFullYear()} Georgia Ray
          </p>
        </div>
      </div>
    </div>
  </footer>

</BaseLayout>
