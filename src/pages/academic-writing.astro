---
import SidebarLayout from "../layouts/SidebarLayout.astro";

const papers = [
  {
    title: "Paper title goes here: a long subtitle that explains the contribution",
    venue: "NeurIPS 20XX",
    authors: "G. Ray, A. Collaborator, B. Another",
    abstract: "Placeholder abstract. A sentence or two about what the paper does, what the key insight is, and what the results show.",
    links: [
      { label: "arXiv", href: "#" },
      { label: "PDF", href: "#" },
      { label: "Code", href: "https://github.com/georgiaray" },
    ],
    type: "Conference",
  },
  {
    title: "Another paper title",
    venue: "ICML 20XX",
    authors: "G. Ray, C. Third",
    abstract: "Placeholder abstract. A sentence or two about what the paper does and why it matters.",
    links: [
      { label: "arXiv", href: "#" },
      { label: "Poster", href: "#" },
    ],
    type: "Conference",
  },
  {
    title: "A workshop paper or preprint",
    venue: "NeurIPS Workshop on [Topic], 20XX",
    authors: "G. Ray",
    abstract: "Placeholder abstract. Workshop paper, preprint, or extended abstract.",
    links: [
      { label: "PDF", href: "#" },
    ],
    type: "Workshop",
  },
];
---

<SidebarLayout title="Academic Writing" description="Papers and research by Georgia Ray.">
  <section class="mb-16">
    <h1 class="font-serif text-4xl font-bold mb-2" style="color: var(--foreground);">Academic Writing</h1>
    <p class="text-base" style="color: var(--muted-foreground);">Papers, preprints, and workshop contributions.</p>
  </section>

  <div class="space-y-8">
    {papers.map((paper, i) => (
      <article
        class="fade-up py-6 border-b"
        style="border-color: var(--border);"
      >
        <div class="flex items-start gap-3 mb-2">
          <span
            class="text-xs px-2 py-0.5 rounded-full font-medium shrink-0 mt-1"
            style={paper.type === "Conference"
              ? "background-color: var(--primary); color: var(--primary-foreground);"
              : "background-color: var(--accent); color: var(--accent-foreground);"}
          >
            {paper.type}
          </span>
          <h2 class="font-serif text-lg font-semibold leading-snug" style="color: var(--foreground);">{paper.title}</h2>
        </div>
        <p class="text-sm mb-1 ml-[52px]" style="color: var(--primary);">{paper.venue}</p>
        <p class="text-xs mb-3 ml-[52px]" style="color: var(--muted-foreground);">{paper.authors}</p>
        <p class="text-sm leading-relaxed mb-4 ml-[52px]" style="color: var(--muted-foreground);">{paper.abstract}</p>
        <div class="flex gap-4 ml-[52px]">
          {paper.links.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium underline underline-offset-2 transition-opacity hover:opacity-70"
              style="color: var(--primary);"
            >
              {link.label}
            </a>
          ))}
        </div>
      </article>
    ))}
  </div>
</SidebarLayout>
