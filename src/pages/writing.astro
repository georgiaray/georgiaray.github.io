---
import SidebarLayout from "../layouts/SidebarLayout.astro";

const posts = [
  {
    title: "A thing I've been thinking about",
    date: "March 2026",
    excerpt: "Placeholder: a couple of sentences that give the flavour of the piece. What's the question, the observation, or the tension you're exploring?",
    href: "#",
    tag: "ML",
  },
  {
    title: "Why [thing] is more interesting than it sounds",
    date: "January 2026",
    excerpt: "Placeholder: another post. This one is more explainer-y — you're making something technical feel approachable for a non-specialist.",
    href: "#",
    tag: "Explainer",
  },
  {
    title: "Notes on [paper / concept / experiment]",
    date: "November 2025",
    excerpt: "Placeholder: informal notes, half-formed thoughts, something you read or tried that you wanted to write down before you forgot it.",
    href: "#",
    tag: "Notes",
  },
  {
    title: "Something non-ML",
    date: "September 2025",
    excerpt: "Placeholder: not everything has to be about work. A post about something else you care about — a book, an idea, an observation about the world.",
    href: "#",
    tag: "Other",
  },
];
---

<SidebarLayout title="Casual Writing" description="Blog posts and informal writing by Georgia Ray.">
  <section class="mb-16">
    <h1 class="font-serif text-4xl font-bold mb-2" style="color: var(--foreground);">Casual Writing</h1>
    <p class="text-base" style="color: var(--muted-foreground);">Less formal than a paper, more considered than a tweet. Ideas I wanted to write down.</p>
  </section>

  <div class="space-y-0">
    {posts.map((post, i) => (
      <a
        href={post.href}
        class="fade-up group block py-6 border-b transition-colors"
        style="border-color: var(--border);"
      >
        <div class="flex items-center gap-3 mb-2">
          <span
            class="text-xs px-2 py-0.5 rounded-full font-medium"
            style="background-color: var(--accent); color: var(--accent-foreground);"
          >
            {post.tag}
          </span>
          <span class="text-xs" style="color: var(--muted-foreground);">{post.date}</span>
        </div>
        <h2
          class="font-serif text-xl font-semibold mb-2 transition-colors group-hover:opacity-80"
          style="color: var(--foreground);"
        >
          {post.title}
        </h2>
        <p class="text-sm leading-relaxed" style="color: var(--muted-foreground);">{post.excerpt}</p>
      </a>
    ))}
  </div>
</SidebarLayout>
