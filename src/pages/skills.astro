---
import SidebarLayout from "../layouts/SidebarLayout.astro";

const categories = [
  {
    name: "ML & Research",
    items: ["PyTorch", "JAX", "HuggingFace Transformers", "scikit-learn", "Weights & Biases", "CUDA"],
  },
  {
    name: "Languages",
    items: ["Python", "TypeScript / JavaScript", "Bash", "SQL", "R"],
  },
  {
    name: "Infrastructure",
    items: ["Docker", "Kubernetes", "GCP / AWS", "GitHub Actions", "Ray", "SLURM"],
  },
  {
    name: "Data",
    items: ["Pandas", "Polars", "DuckDB", "Apache Spark", "BigQuery"],
  },
  {
    name: "Frontend & Viz",
    items: ["Astro", "React", "D3.js", "Observable", "Tailwind CSS"],
  },
  {
    name: "Tools",
    items: ["Vim / Neovim", "Jupyter", "Git", "LaTeX", "Zotero"],
  },
];
---

<SidebarLayout title="Skills & Tools" description="Georgia Ray's technical skills and toolset.">
  <section class="mb-16">
    <h1 class="font-serif text-4xl font-bold mb-2" style="color: var(--foreground);">Skills & Tools</h1>
    <p class="text-base" style="color: var(--muted-foreground);">Things I use regularly and feel confident in. Not an exhaustive list.</p>
  </section>

  <div class="grid gap-10">
    {categories.map((cat, i) => (
      <section class="fade-up">
        <h2 class="font-serif text-lg font-semibold mb-4" style="color: var(--foreground);">{cat.name}</h2>
        <div class="flex flex-wrap gap-2">
          {cat.items.map(item => (
            <span
              class="text-sm px-3 py-1.5 rounded-md font-medium border transition-colors"
              style="background-color: var(--card); color: var(--foreground); border-color: var(--border);"
            >
              {item}
            </span>
          ))}
        </div>
      </section>
    ))}
  </div>
</SidebarLayout>
